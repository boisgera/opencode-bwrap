#!/usr/bin/env bash
exec bwrap \
  --ro-bind /usr /usr \
  --ro-bind /bin /bin \
  --ro-bind /lib /lib \
  --ro-bind /lib64 /lib64 \
  --ro-bind /etc/ssl /etc/ssl \
  --ro-bind /etc/resolv.conf /etc/resolv.conf \
  --ro-bind /etc/nsswitch.conf /etc/nsswitch.conf \
  --ro-bind /etc/passwd /etc/passwd \
  --ro-bind /etc/group /etc/group \
  --proc /proc \
  --dev /dev \
  --tmpfs /tmp \
  --bind "$PWD" "$PWD" \
  --chdir "$PWD" \
  --bind "${XDG_CONFIG_HOME:-$HOME/.config}/opencode" "${XDG_CONFIG_HOME:-$HOME/.config}/opencode" \
  --share-net \
  --new-session \
  --die-with-parent \
  -- opencode "$@"